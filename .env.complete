# ===================================
# Daily Stock Analysis - 完整配置示例
# ===================================

# -----------------------------------
# 股票列表
# -----------------------------------
STOCK_LIST=AAPL,MSFT,NVDA,GOOGL,TSLA,600519,hk00700

# -----------------------------------
# LLM 配置（使用 OpenAI 兼容格式）
# -----------------------------------
OPENAI_API_KEY=84915a62-b2c0-4cf8-b00c-3d1f7fa5dc27
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OPENAI_MODEL=ark-code-latest

# -----------------------------------
# 搜索 API
# -----------------------------------
BRAVE_API_KEYS=BSAFVlJs1Vp53sPVrHVlnS-ccilgf--

# -----------------------------------
# 分析参数
# -----------------------------------
# 乖离率阈值（%），超过提示不追高
BIAS_THRESHOLD=5.0

# 新闻最大时效（天）
NEWS_MAX_AGE_DAYS=3

# 报告类型：simple / full / brief
REPORT_TYPE=full

# -----------------------------------
# Agent 策略
# -----------------------------------
# 启用的交易策略
AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,shrink_pullback

# Agent 最大推理步数
AGENT_MAX_STEPS=10

# -----------------------------------
# 通知渠道（可选）
# -----------------------------------
# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# 邮件推送
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=

# 企业微信
# WECHAT_WEBHOOK_URL=

# 飞书
# FEISHU_WEBHOOK_URL=

# PushPlus
# PUSHPLUS_TOKEN=

# -----------------------------------
# 定时任务（可选）
# -----------------------------------
# SCHEDULE_ENABLED=true
# SCHEDULE_TIME=18:00
# RUN_IMMEDIATELY=true
# TRADING_DAY_CHECK_ENABLED=true

# -----------------------------------
# 调试选项
# -----------------------------------
DEBUG=false
DRY_RUN=false
LOG_LEVEL=INFO
